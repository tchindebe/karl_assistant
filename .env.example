# ============================================================
# Karl — Configuration
# Copier en .env et remplir les valeurs
# ============================================================

# ─── Provider LLM ──────────────────────────────────────────
# Valeurs disponibles: anthropic | openai | ollama | gemini
PROVIDER=anthropic

# ─── Anthropic / Claude (si PROVIDER=anthropic) ────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-opus-4-6
# Autres modèles Claude: claude-sonnet-4-6, claude-haiku-4-5

# ─── OpenAI (si PROVIDER=openai) ───────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# Autres modèles OpenAI: gpt-4o-mini, o1, o3-mini, o3
# Laisser vide pour l'API officielle OpenAI:
# OPENAI_BASE_URL=

# ─── Ollama — modèles locaux (si PROVIDER=ollama) ──────────
# Ollama doit tourner sur le serveur: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
# Autres modèles Ollama: mistral, qwen2.5, deepseek-r1, codellama

# ─── Google Gemini (si PROVIDER=gemini) ────────────────────
# Clé API: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
# Autres modèles Gemini: gemini-1.5-pro, gemini-1.5-flash

# ─── VPS Agent ─────────────────────────────────────────────
# URL de l'agent installé sur le VPS
VPS_AGENT_URL=http://YOUR_VPS_IP:8001
# Même clé que KARL_AGENT_API_KEY dans le VPS Agent
VPS_AGENT_API_KEY=CHANGE_ME_RANDOM_SECRET_KEY
VPS_AGENT_TIMEOUT=120

# ─── Auth (Karl Brain) ─────────────────────────────────────
KARL_ADMIN_PASSWORD=CHANGE_ME_PASSWORD
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET
JWT_EXPIRE_HOURS=24

# ─── App ───────────────────────────────────────────────────
APP_PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Odoo CRM (optionnel) ──────────────────────────────────
ODOO_URL=https://your-odoo.com
ODOO_DB=your-database
ODOO_USERNAME=admin
ODOO_API_KEY=your-odoo-api-key

# ─── Analytics — Plausible (optionnel, recommandé) ─────────
PLAUSIBLE_API_KEY=your-plausible-api-key
PLAUSIBLE_SITE_ID=monsite.com

# ─── Analytics — GA4 (optionnel, alternative à Plausible) ──
GA4_PROPERTY_ID=123456789
# JSON de la clé de service Google (copier en une ligne)
GA4_CREDENTIALS_JSON={"type":"service_account",...}
