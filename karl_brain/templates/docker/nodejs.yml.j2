version: "3.8"
services:
  {{ name }}:
    image: {{ image or "node:20-alpine" }}
    container_name: {{ name }}
    restart: unless-stopped
    working_dir: /app
    ports:
      - "{{ port or 3000 }}:{{ port or 3000 }}"
    volumes:
      - ./app:/app
      - /app/node_modules
    command: ["node", "index.js"]
    {% if env_vars %}
    environment:
      {% for k, v in env_vars.items() %}
      - {{ k }}={{ v }}
      {% endfor %}
    {% endif %}
    labels:
      - "karl.app={{ name }}"
      - "karl.stack=nodejs"
