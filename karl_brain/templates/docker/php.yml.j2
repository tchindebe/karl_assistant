version: "3.8"
services:
  {{ name }}:
    image: {{ image or "php:8.3-apache" }}
    container_name: {{ name }}
    restart: unless-stopped
    ports:
      - "{{ port or 80 }}:80"
    volumes:
      - ./app:/var/www/html
    {% if env_vars %}
    environment:
      {% for k, v in env_vars.items() %}
      - {{ k }}={{ v }}
      {% endfor %}
    {% endif %}
    labels:
      - "karl.app={{ name }}"
      - "karl.stack=php"
