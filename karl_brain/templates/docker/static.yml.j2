version: "3.8"
services:
  {{ name }}:
    image: {{ image or "nginx:alpine" }}
    container_name: {{ name }}
    restart: unless-stopped
    ports:
      - "{{ port or 80 }}:80"
    volumes:
      - ./dist:/usr/share/nginx/html:ro
    labels:
      - "karl.app={{ name }}"
      - "karl.stack=static"
